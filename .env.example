# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # Use ONLY in server-side webhook code

# Meta / WhatsApp Cloud API
META_APP_ID=
META_APP_SECRET=                    # Used to verify webhook signatures
META_WHATSAPP_VERIFY_TOKEN=         # You choose this — must match Meta dashboard setting

# AI Models
SARVAM_API_KEY=                     # https://sarvam.ai — Hindi AI, STT, TTS
OPENAI_API_KEY=                     # Fallback for complex reasoning
# OR
GROK_API_KEY=                       # Alternative fallback

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (Resend)
RESEND_API_KEY=
FROM_EMAIL=noreply@whatsai.in

# Encryption (for storing WhatsApp access tokens)
ENCRYPTION_KEY=                     # 32-byte hex string for AES-256

# App
NEXT_PUBLIC_APP_URL=https://app.whatsai.in
CRON_SECRET=                        # Secret to protect /api/reminders/process
